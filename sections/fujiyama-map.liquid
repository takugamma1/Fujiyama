{%- comment -%}
  FUJIYAMA location — dark map (baked from the mockup, links to Google Maps)
  beside a gold double-bordered info card, with the round emblem stamped
  under the map column.
{%- endcomment -%}

<section class="f-section f-map">
  <span class="f-anchor" id="kontakti"></span>
  <div class="f-map-inner">
    {%- liquid
      if section.settings.map_embed_url != blank
        assign map_src = section.settings.map_embed_url
      else
        assign map_q = section.settings.address | strip_html | append: ', ' | append: section.settings.city | url_encode
        assign map_src = 'https://maps.google.com/maps?q=' | append: map_q | append: '&z=15&output=embed'
      endif
    -%}
    <div class="f-map-embed">
      <iframe src="{{ map_src }}" title="Карта — {{ section.settings.city | escape }}"
              loading="lazy" referrerpolicy="no-referrer-when-downgrade" allowfullscreen></iframe>
    </div>

    <div class="f-map-card">
      <svg class="f-pin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path d="M12 21s-6.4-5.7-6.4-10.4a6.4 6.4 0 1 1 12.8 0C18.4 15.3 12 21 12 21z"/><circle cx="12" cy="10.4" r="2.3"/>
      </svg>
      <h2 class="f-display f-map-city">{{ section.settings.city | escape }}</h2>
      <p class="f-map-country">{{ section.settings.country | escape }}</p>

      <ul class="f-map-list">
        <li>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M12 21s-6.4-5.7-6.4-10.4a6.4 6.4 0 1 1 12.8 0C18.4 15.3 12 21 12 21z"/><circle cx="12" cy="10.4" r="2.3"/></svg>
          <div class="f-map-addr">{{ section.settings.address }}</div>
        </li>
        <li>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M5 4.5h3.2l1.6 4-2 1.5a12.5 12.5 0 0 0 5.7 5.7l1.5-2 4 1.6V19a1.5 1.5 0 0 1-1.6 1.5C10 20 4 14 3.5 6.1A1.5 1.5 0 0 1 5 4.5z"/></svg>
          <a href="tel:{{ section.settings.phone | remove: ' ' }}">{{ section.settings.phone | escape }}</a>
        </li>
        <li>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3.4" y="5.4" width="17.2" height="13.2" rx="1.6"/><path d="m4.4 6.6 7.6 6 7.6-6"/></svg>
          <a href="mailto:{{ section.settings.email }}">{{ section.settings.email | escape }}</a>
        </li>
      </ul>

      <p class="f-map-sub">{{ section.settings.hours_label | escape }}</p>
      <div class="f-map-val">{{ section.settings.hours }}</div>
      <p class="f-map-sub">{{ section.settings.closed_label | escape }}</p>
      <div class="f-map-val">{{ section.settings.closed | escape }}</div>
    </div>
  </div>
</section>

{% style %}
  .f-map-inner {
    position: relative;
    max-width: 1090px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: stretch;
    gap: 22px;
  }
  .f-map-embed {
    flex: 1 1 auto;
    min-width: 0;
    min-height: 380px;
    overflow: hidden;
    border: 1px solid rgba(199, 161, 113, 0.18);
    background: #1b1a18;
  }
  .f-map-embed iframe {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
    /* tint the real Google map to the dark theme (no API key needed) */
    filter: invert(0.91) hue-rotate(180deg) brightness(0.92) contrast(0.9) saturate(0.55) sepia(0.18);
  }

  .f-map-card {
    position: relative;
    flex: 0 0 332px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    border: 1px solid rgba(199, 161, 113, 0.65);
    padding: 32px 30px;
    text-align: center;
    background: rgba(10, 10, 10, 0.25);
  }
  .f-map-card::before {
    content: '';
    position: absolute;
    inset: 8px;
    border: 1px solid rgba(199, 161, 113, 0.3);
    pointer-events: none;
  }
  .f-pin { width: 20px; height: 20px; color: var(--f-gold); margin-bottom: 10px; }
  .f-map-city {
    font-size: clamp(22px, 2.3vw, 28px);
    letter-spacing: 0.22em;
    text-indent: 0.22em;
    text-transform: uppercase;
  }
  .f-map-country {
    font-size: 10px;
    letter-spacing: 0.4em;
    text-indent: 0.4em;
    text-transform: uppercase;
    color: var(--f-gold-dim);
    margin: 8px 0 18px;
  }
  .f-map-list {
    list-style: none;
    margin: 0 auto 20px;
    padding: 0 0 18px;
    max-width: 250px;
    text-align: left;
    border-bottom: 1px solid rgba(199, 161, 113, 0.25);
  }
  .f-map-list li {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    font-size: 13px;
    line-height: 1.55;
    color: #c5bca9;
    margin-bottom: 13px;
  }
  .f-map-list li:last-child { margin-bottom: 0; }
  .f-map-list svg { width: 15px; height: 15px; flex: 0 0 auto; margin-top: 2px; color: var(--f-gold); }
  .f-map-list a:hover { color: var(--f-gold); }
  .f-map-sub {
    font-size: 11px;
    letter-spacing: 0.3em;
    text-indent: 0.3em;
    text-transform: uppercase;
    color: var(--f-gold);
    margin: 0 0 7px;
  }
  .f-map-val { font-size: 13px; line-height: 1.6; color: #c5bca9; margin: 0 0 13px; }
  .f-map-val:last-child { margin-bottom: 0; }
  .f-map-val p, .f-map-addr p { margin: 0; }

  @media (max-width: 849px) {
    .f-map-inner { flex-direction: column; align-items: stretch; padding: 0 24px 56px; }
    .f-map-embed { flex-basis: auto; width: 100%; margin: 0 0 26px; min-height: 0; aspect-ratio: 16 / 11; }
    .f-map-card { flex-basis: auto; width: 100%; }
  }
{% endstyle %}

{% schema %}
{
  "name": "Fujiyama локация",
  "settings": [
    { "type": "text", "id": "map_embed_url", "label": "Google Maps embed URL (по избор)", "info": "Google Maps → Споделяне → Вграждане на карта → копирай адреса от src. Празно = автоматично от адреса по-долу." },
    { "type": "text", "id": "city", "label": "Град", "default": "Пазарджик" },
    { "type": "text", "id": "country", "label": "Държава", "default": "България" },
    { "type": "richtext", "id": "address", "label": "Адрес", "default": "<p>ул. Цар Иван Шишман 15<br>4400 Пазарджик, България</p>" },
    { "type": "text", "id": "phone", "label": "Телефон", "default": "+359 88 123 45 67" },
    { "type": "text", "id": "email", "label": "Имейл", "default": "rezervacii@fujiyama.bg" },
    { "type": "text", "id": "hours_label", "label": "Етикет работно време", "default": "Работно време" },
    { "type": "richtext", "id": "hours", "label": "Работно време", "default": "<p>Понеделник – Събота<br>12:00 – 23:00</p>" },
    { "type": "text", "id": "closed_label", "label": "Етикет почивен ден", "default": "Почивен ден" },
    { "type": "text", "id": "closed", "label": "Почивен ден", "default": "Неделя вечер" }
  ],
  "presets": [{ "name": "Fujiyama локация" }]
}
{% endschema %}
