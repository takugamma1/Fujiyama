{%- comment -%}
  FUJIYAMA menu hero — Mt-Fuji ink illustration (cream top → grainy charcoal
  bottom that dissolves into the next section). Live text overlays:
  FUJIYAMA wordmark + BAR & DINNER on the cream sky; [01] МЕНЮ + subtitle over
  the dark mountain base. The illustration's feathered bottom + the shared
  charcoal-grain background make the seam invisible.
{%- endcomment -%}

<section class="f-section f-mh">
  <div class="f-mh-board">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 1881 | image_tag: alt: '', class: 'f-mh-art', loading: 'eager', fetchpriority: 'high' }}
    {%- else -%}
      <img class="f-mh-art" src="{{ 'fujiyama-menu-hero.webp' | asset_url }}" alt="" width="1881" height="836" loading="eager" fetchpriority="high">
    {%- endif -%}

    <div class="f-mh-top">
      <p class="f-mh-word">{{ section.settings.brand | escape }}</p>
      {%- if section.settings.tagline != blank -%}
        <p class="f-mh-tag"><span>{{ section.settings.tagline | escape }}</span></p>
      {%- endif -%}
    </div>

    <div class="f-mh-bottom">
      <p class="f-label f-mh-label"><span class="f-label-num">[01]</span>{{ section.settings.label | escape }}</p>
      <h1 class="f-display f-mh-title">{{ section.settings.title | escape }}</h1>
      {%- if section.settings.subtitle != blank -%}
        <p class="f-mh-sub">{{ section.settings.subtitle | escape }}</p>
      {%- endif -%}
    </div>
  </div>
</section>

{% style %}
  .f-mh { overflow: hidden; padding: 0; }
  .f-mh-board { position: relative; }
  .f-mh-art { display: block; width: 100%; height: auto; }

  .f-mh-top {
    position: absolute;
    top: 8.5%;
    left: 0;
    right: 0;
    text-align: center;
  }
  .f-mh-word {
    margin: 0;
    font-family: 'Italiana', var(--f-serif);
    font-weight: 400;
    color: #20201d;
    font-size: clamp(34px, 8.4vw, 150px);
    line-height: 1;
    letter-spacing: 0.14em;
    text-indent: 0.14em;
  }
  .f-mh-tag {
    margin: clamp(6px, 1.4vw, 20px) 0 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(10px, 1.6vw, 22px);
    color: var(--f-gold-dim);
    font-family: var(--f-sans);
    font-size: clamp(9px, 1.05vw, 15px);
    font-weight: 500;
    letter-spacing: 0.42em;
    text-indent: 0.42em;
    text-transform: uppercase;
  }
  .f-mh-tag span { position: relative; padding: 0 clamp(14px, 2vw, 30px); }
  .f-mh-tag span::before,
  .f-mh-tag span::after {
    content: '';
    position: absolute;
    top: 50%;
    width: clamp(28px, 4vw, 64px);
    height: 1px;
    background: var(--f-gold-dim);
  }
  .f-mh-tag span::before { right: 100%; }
  .f-mh-tag span::after { left: 100%; }

  .f-mh-bottom {
    position: absolute;
    bottom: 6.5%;
    left: 0;
    right: 0;
    text-align: center;
    color: var(--f-cream);
  }
  .f-mh-label { display: flex; justify-content: center; font-size: clamp(9px, 1vw, 13px); margin: 0 0 clamp(6px, 1vw, 14px); color: var(--f-gold); }
  .f-mh-label .f-label-num { color: var(--f-gold); margin-right: 0.7em; }
  .f-mh-title {
    margin: 0;
    font-size: clamp(30px, 5.6vw, 86px);
    line-height: 1;
    letter-spacing: 0.04em;
    text-indent: 0.04em;
    text-transform: uppercase;
    color: #f3ecdd;
  }
  .f-mh-sub {
    margin: clamp(8px, 1.3vw, 18px) 0 0;
    font-size: clamp(9px, 1.05vw, 14px);
    letter-spacing: 0.3em;
    text-indent: 0.3em;
    text-transform: uppercase;
    color: #b8ad98;
  }

  /* On narrow screens the 2.25:1 art is too short for the overlays — crop it
     taller (cover) so the wordmark + menu title keep breathing room. */
  @media (max-width: 749px) {
    .f-mh-board { aspect-ratio: 4 / 5; }
    .f-mh-art { height: 100%; object-fit: cover; object-position: 50% 42%; }
    .f-mh-top { top: 9%; }
    .f-mh-bottom { bottom: 7%; }
  }
{% endstyle %}

{% schema %}
{
  "name": "Fujiyama меню хедър",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Арт изображение (по подразбиране — вграденото)" },
    { "type": "text", "id": "brand", "label": "Марка", "default": "FUJIYAMA" },
    { "type": "text", "id": "tagline", "label": "Слоган", "default": "BAR & DINNER" },
    { "type": "text", "id": "label", "label": "Етикет (до номера [01])" },
    { "type": "text", "id": "title", "label": "Заглавие", "default": "Меню" },
    { "type": "text", "id": "subtitle", "label": "Подзаглавие", "default": "Свежест, качество и изкуство във всяко ястие" }
  ],
  "presets": [{ "name": "Fujiyama меню хедър" }]
}
{% endschema %}
