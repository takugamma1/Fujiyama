{%- comment -%}
  FUJIYAMA FAQ — ink hero (cream top → dark feathered merge) with live FAQ
  title, a numbered accordion (native details/summary), and a contact CTA bar.
{%- endcomment -%}

<section class="f-section f-fq-hero">
  <div class="f-fq-board">
    {%- if section.settings.hero_image != blank -%}
      {{ section.settings.hero_image | image_url: width: 2000 | image_tag: alt: '', class: 'f-fq-art', loading: 'eager', fetchpriority: 'high' }}
    {%- else -%}
      <img class="f-fq-art" src="{{ 'fujiyama-faq-hero.webp' | asset_url }}" alt="" width="1881" height="836" loading="eager" fetchpriority="high">
    {%- endif -%}
    <div class="f-fq-top">
      <h1 class="f-display f-fq-title">{{ section.settings.title | escape }}</h1>
      {%- if section.settings.tagline != blank -%}
        <p class="f-fq-tag"><span>{{ section.settings.tagline | escape }}</span></p>
      {%- endif -%}
      {%- if section.settings.subtitle != blank -%}
        <p class="f-fq-sub">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>
  </div>
</section>

<section class="f-section f-fq">
  <span class="f-anchor" id="faq"></span>
  <div class="f-fq-wrap">
    <ul class="f-fq-list" role="list">
      {%- for block in section.blocks -%}
        <li {{ block.shopify_attributes }}>
          <details class="f-fq-item"{% if section.settings.open_first and forloop.first %} open{% endif %}>
            <summary class="f-fq-q">
              <span class="f-fq-num">{% if forloop.index < 10 %}0{% endif %}{{ forloop.index }}</span>
              <span class="f-fq-qtext">{{ block.settings.question | escape }}</span>
              <span class="f-fq-chev" aria-hidden="true">
                <svg viewBox="0 0 14 9" fill="none" stroke="currentColor" stroke-width="1.5"><path d="m1.5 1.8 5.5 5.4 5.5-5.4"/></svg>
              </span>
            </summary>
            <div class="f-fq-a">{{ block.settings.answer }}</div>
          </details>
        </li>
      {%- else -%}
        <li class="f-fq-empty">Добавете въпроси в редактора.</li>
      {%- endfor -%}
    </ul>

    {%- if section.settings.cta_heading != blank -%}
      <div class="f-fq-cta">
        <span class="f-fq-cta-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 13v-1a8 8 0 0 1 16 0v1"/><path d="M4 13.5a2 2 0 0 1 2-2h.5v6H6a2 2 0 0 1-2-2zM20 13.5a2 2 0 0 0-2-2h-.5v6h.5a2 2 0 0 0 2-2z"/><path d="M20 17v.5a3.5 3.5 0 0 1-3.5 3.5H13"/></svg>
        </span>
        <div class="f-fq-cta-text">
          <p class="f-fq-cta-h">{{ section.settings.cta_heading | escape }}</p>
          {%- if section.settings.cta_text != blank -%}<p class="f-fq-cta-sub">{{ section.settings.cta_text | escape }}</p>{%- endif -%}
        </div>
        <a class="f-btn-gold f-fq-cta-btn" href="{{ section.settings.cta_link | default: '/pages/reservation' }}">
          {{ section.settings.cta_button | escape }}
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" width="15" height="15" aria-hidden="true"><path d="M2 8h11M9 3.5 13.5 8 9 12.5"/></svg>
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% style %}
  /* hero (shares the menu/reservation hero treatment) */
  .f-fq-hero { overflow: hidden; padding: 0; }
  .f-fq-board { position: relative; }
  .f-fq-art { display: block; width: 100%; height: auto; }
  .f-fq-top { position: absolute; top: 9%; left: 0; right: 0; text-align: center; padding: 0 6%; }
  .f-fq-title {
    margin: 0; font-family: 'Italiana', var(--f-serif); font-weight: 400; color: #25241f;
    font-size: clamp(40px, 7vw, 104px); line-height: 1; letter-spacing: 0.06em; text-transform: uppercase;
  }
  .f-fq-tag {
    margin: clamp(8px,1.4vw,18px) 0 0; display: flex; align-items: center; justify-content: center; gap: clamp(10px,1.6vw,20px);
    color: var(--f-gold-dim); font-size: clamp(9px,1vw,13px); font-weight: 500; letter-spacing: 0.36em; text-indent: 0.36em; text-transform: uppercase;
  }
  .f-fq-tag span { position: relative; padding: 0 clamp(12px,1.6vw,24px); }
  .f-fq-tag span::before, .f-fq-tag span::after { content: ''; position: absolute; top: 50%; width: clamp(24px,3.4vw,52px); height: 1px; background: var(--f-gold-dim); }
  .f-fq-tag span::before { right: 100%; } .f-fq-tag span::after { left: 100%; }
  .f-fq-sub { margin: clamp(12px,1.8vw,24px) auto 0; max-width: 30em; font-size: clamp(12px,1.1vw,16px); line-height: 1.7; color: #4f4a40; }

  /* accordion */
  .f-fq { padding: clamp(28px,4vw,56px) 4.7% clamp(48px,6vw,88px); }
  .f-anchor { display: block; scroll-margin-top: 70px; }
  .f-fq-wrap { max-width: 920px; margin: 0 auto; }
  .f-fq-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 14px; }
  .f-fq-item {
    border: 1px solid rgba(232,225,210,0.12);
    border-radius: 12px;
    background: rgba(255,255,255,0.02);
    transition: border-color .25s ease, background .25s ease;
  }
  .f-fq-item[open] { border-color: rgba(199,161,113,0.45); background: rgba(255,255,255,0.035); }
  .f-fq-q {
    display: flex; align-items: center; gap: 20px;
    padding: clamp(18px,2vw,26px) clamp(20px,2.4vw,32px);
    cursor: pointer; list-style: none; user-select: none;
  }
  .f-fq-q::-webkit-details-marker { display: none; }
  .f-fq-num { flex: 0 0 auto; font-family: var(--f-serif); font-size: clamp(15px,1.5vw,19px); color: var(--f-gold); padding-right: 20px; border-right: 1px solid rgba(199,161,113,0.35); }
  .f-fq-qtext { flex: 1 1 auto; font-size: clamp(14px,1.3vw,17px); font-weight: 500; letter-spacing: 0.02em; color: var(--f-cream); line-height: 1.4; }
  .f-fq-chev { flex: 0 0 auto; color: var(--f-gold); display: inline-flex; transition: transform .3s ease; }
  .f-fq-chev svg { width: 14px; height: 9px; }
  .f-fq-item[open] .f-fq-chev { transform: rotate(180deg); }
  .f-fq-a {
    padding: 0 clamp(20px,2.4vw,32px) clamp(20px,2.2vw,28px) calc(clamp(20px,2.4vw,32px) + 40px);
    font-size: clamp(13px,1.1vw,15px); line-height: 1.75; color: var(--f-body);
    animation: f-fq-fade .35s ease;
  }
  .f-fq-a p { margin: 0 0 0.7em; } .f-fq-a p:last-child { margin-bottom: 0; }
  @keyframes f-fq-fade { from { opacity: 0; transform: translateY(-4px); } to { opacity: 1; transform: none; } }

  /* contact CTA */
  .f-fq-cta {
    display: flex; align-items: center; gap: clamp(16px,2.4vw,30px);
    margin-top: clamp(28px,3vw,44px);
    padding: clamp(22px,2.4vw,32px) clamp(24px,3vw,40px);
    border: 1px solid rgba(199,161,113,0.35); border-radius: 14px;
    background: rgba(255,255,255,0.02);
  }
  .f-fq-cta-icon { flex: 0 0 auto; width: 56px; height: 56px; border: 1px solid rgba(199,161,113,0.5); border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; color: var(--f-gold); }
  .f-fq-cta-icon svg { width: 26px; height: 26px; }
  .f-fq-cta-text { flex: 1 1 auto; min-width: 0; }
  .f-fq-cta-h { margin: 0; font-family: var(--f-serif); font-size: clamp(16px,1.6vw,21px); font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: var(--f-cream); }
  .f-fq-cta-sub { margin: 6px 0 0; font-size: clamp(12px,1vw,14px); color: var(--f-body); }
  .f-fq-cta-btn { flex: 0 0 auto; gap: 10px; height: 50px; padding: 0 28px; border-radius: 5px; white-space: nowrap; }

  @media (max-width: 749px) {
    .f-fq-board { aspect-ratio: 4 / 5; }
    .f-fq-art { height: 100%; object-fit: cover; object-position: 50% 42%; }
    .f-fq-top { top: 8%; }
    .f-fq-num { padding-right: 14px; }
    .f-fq-q { gap: 14px; }
    .f-fq-a { padding-left: clamp(20px,2.4vw,32px); }
    .f-fq-cta { flex-direction: column; text-align: center; }
    .f-fq-cta-btn { width: 100%; }
  }
{% endstyle %}

{% schema %}
{
  "name": "Fujiyama FAQ",
  "settings": [
    { "type": "image_picker", "id": "hero_image", "label": "Арт изображение — по подразбиране вграденото" },
    { "type": "text", "id": "title", "label": "Заглавие", "default": "FAQ" },
    { "type": "text", "id": "tagline", "label": "Слоган", "default": "Често задавани въпроси" },
    { "type": "textarea", "id": "subtitle", "label": "Подзаглавие", "default": "Тук ще откриете отговори на най-често задаваните въпроси от нашите гости." },
    { "type": "checkbox", "id": "open_first", "label": "Първият въпрос отворен", "default": true },
    { "type": "header", "content": "Долен блок (контакт)" },
    { "type": "text", "id": "cta_heading", "label": "Заглавие", "default": "Не намерихте отговор?" },
    { "type": "text", "id": "cta_text", "label": "Текст", "default": "Свържете се с нас и ще се радваме да ви помогнем." },
    { "type": "text", "id": "cta_button", "label": "Бутон", "default": "Свържете се с нас" },
    { "type": "text", "id": "cta_link", "label": "Линк на бутона", "default": "/pages/reservation" }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Въпрос",
      "settings": [
        { "type": "text", "id": "question", "label": "Въпрос", "default": "Въпрос?" },
        { "type": "richtext", "id": "answer", "label": "Отговор", "default": "<p>Отговор на въпроса.</p>" }
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [{ "name": "Fujiyama FAQ" }]
}
{% endschema %}
