{%- comment -%}
  FUJIYAMA collection cards — one card per collection (dynamic).
  Card = photo (collection.image → first product image → placeholder)
       + collection title
       + "ВИЖ {title} →" button linking to the collection.
  Pick collections in the editor, or leave empty to auto-list every collection
  (excluding the default "frontpage"/"Home page"). Dark cards on the shared
  charcoal-grain background — no separate text panel.
{%- endcomment -%}

{%- liquid
  assign cols = section.settings.collections
  assign use_all = false
  if cols == empty
    assign use_all = true
  endif
-%}

<section class="f-section f-cc">
  <span class="f-anchor" id="kolekcii"></span>
  {%- if section.settings.heading != blank -%}
    <div class="f-cc-head">
      {%- if section.settings.eyebrow != blank -%}
        <p class="f-label f-cc-eyebrow"><span class="f-label-num">[02]</span>{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      <h2 class="f-display f-cc-heading">{{ section.settings.heading | escape }}</h2>
    </div>
  {%- endif -%}

  <ul class="f-cc-grid" style="--f-cc-cols: {{ section.settings.columns }};" role="list">
    {%- if use_all -%}
      {%- assign source = collections -%}
    {%- else -%}
      {%- assign source = cols -%}
    {%- endif -%}

    {%- for collection in source -%}
      {%- if collection.handle == 'frontpage' -%}{%- continue -%}{%- endif -%}

      {%- liquid
        assign card_image = collection.image
        if card_image == blank
          for product in collection.products limit: 8
            if product.featured_image
              assign card_image = product.featured_image
              break
            endif
          endfor
        endif
        assign verb = section.settings.button_verb | default: 'Виж'
      -%}

      <li class="f-cc-card">
        <a class="f-cc-link" href="{{ collection.url }}" aria-label="{{ verb }} {{ collection.title | escape }}">
          <span class="f-cc-media">
            {%- if card_image != blank -%}
              {{ card_image | image_url: width: 700 | image_tag:
                loading: 'lazy', class: 'f-cc-img', widths: '300,460,700',
                sizes: '(max-width: 749px) 80vw, 24vw', alt: collection.title | escape }}
            {%- else -%}
              <span class="f-cc-ph" aria-hidden="true">富士山</span>
            {%- endif -%}
            <span class="f-cc-shade" aria-hidden="true"></span>
          </span>
          <span class="f-cc-body">
            <span class="f-cc-title">{{ collection.title }}</span>
            <span class="f-cc-cta">
              <span class="f-cc-cta-label">{{ verb }} {{ collection.title }}</span>
              <span class="f-arrow f-cc-arrow" aria-hidden="true">
                <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M2 8h11M9 3.5 13.5 8 9 12.5"/></svg>
              </span>
            </span>
          </span>
        </a>
      </li>
    {%- else -%}
      <li class="f-cc-empty">Няма колекции за показване. Добавете колекции в редактора.</li>
    {%- endfor -%}
  </ul>
</section>

{% style %}
  .f-cc { padding: clamp(40px, 6vw, 76px) 4.7% clamp(36px, 5vw, 60px); }
  .f-anchor { display: block; scroll-margin-top: 70px; }
  .f-cc-head { text-align: center; max-width: 1170px; margin: 0 auto clamp(28px, 3.6vw, 48px); }
  .f-cc-eyebrow { display: flex; justify-content: center; font-size: clamp(9px, 1vw, 12px); margin: 0 0 12px; }
  .f-cc-heading {
    font-size: clamp(28px, 4.4vw, 52px);
    letter-spacing: 0.08em;
    text-indent: 0.08em;
    text-transform: uppercase;
  }

  .f-cc-grid {
    list-style: none;
    margin: 0 auto;
    padding: 0;
    max-width: 1280px;
    display: grid;
    grid-template-columns: repeat(var(--f-cc-cols, 4), 1fr);
    gap: clamp(12px, 1.4vw, 20px);
  }
  .f-cc-card { min-width: 0; }
  .f-cc-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    border: 1px solid rgba(232, 225, 210, 0.12);
    border-radius: 10px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.018);
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .f-cc-link:hover {
    transform: translateY(-4px);
    border-color: rgba(199, 161, 113, 0.55);
    box-shadow: 0 18px 36px rgba(0, 0, 0, 0.5);
  }

  .f-cc-media { position: relative; display: block; aspect-ratio: 1 / 1; overflow: hidden; }
  .f-cc-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .f-cc-link:hover .f-cc-img { transform: scale(1.05); }
  .f-cc-ph {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    font-family: 'Noto Serif JP', var(--f-serif);
    font-size: 2.4rem;
    color: rgba(199, 161, 113, 0.5);
    background: #14130f;
  }
  .f-cc-shade {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 55%, rgba(12, 11, 9, 0.55) 100%);
    pointer-events: none;
  }

  .f-cc-body {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: clamp(14px, 1.4vw, 20px) clamp(14px, 1.4vw, 20px) clamp(16px, 1.6vw, 22px);
    flex: 1 1 auto;
  }
  .f-cc-title {
    font-family: var(--f-serif);
    font-weight: 500;
    font-size: clamp(15px, 1.35vw, 20px);
    line-height: 1.2;
    color: var(--f-cream);
    letter-spacing: 0.01em;
  }
  .f-cc-cta {
    margin-top: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
  }
  .f-cc-cta-label {
    font-family: var(--f-sans);
    font-size: clamp(9.5px, 0.82vw, 11px);
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--f-gold);
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .f-cc-arrow { width: 34px; height: 34px; flex: 0 0 auto; }
  .f-cc-link:hover .f-cc-arrow { background: var(--f-gold); border-color: var(--f-gold); color: var(--f-ink); }

  .f-cc-empty { grid-column: 1 / -1; text-align: center; color: var(--f-body); padding: 40px 0; }

  @media (max-width: 1100px) { .f-cc-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 749px) {
    .f-cc { padding-left: 18px; padding-right: 18px; }
    .f-cc-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    .f-cc-cta-label { letter-spacing: 0.1em; }
  }
  @media (max-width: 420px) { .f-cc-grid { grid-template-columns: 1fr 1fr; } }
{% endstyle %}

{% schema %}
{
  "name": "Fujiyama колекции",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Етикет", "default": "Нашето меню" },
    { "type": "text", "id": "heading", "label": "Заглавие", "default": "Разгледай по категория" },
    {
      "type": "collection_list",
      "id": "collections",
      "label": "Колекции (празно = всички)",
      "limit": 30,
      "info": "Подреди категориите. Ако е празно, се показват всички колекции."
    },
    { "type": "text", "id": "button_verb", "label": "Глагол на бутона", "default": "Виж" },
    {
      "type": "range", "id": "columns", "label": "Колони (десктоп)",
      "min": 3, "max": 5, "step": 1, "default": 4
    }
  ],
  "presets": [{ "name": "Fujiyama колекции" }]
}
{% endschema %}
