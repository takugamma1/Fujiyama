{%- comment -%}
  FUJIYAMA footer — flat black bar: round stamp, address, working hours,
  social links, separated by hairline dividers (per the mockup).
{%- endcomment -%}

<footer class="f-section f-footer">
  <div class="f-footer-inner">
    {%- if section.settings.logo != blank -%}
      {{ section.settings.logo | image_url: width: 188 | image_tag: alt: shop.name, class: 'f-footer-stamp' }}
    {%- else -%}
      <img class="f-footer-stamp" src="{{ 'fujiyama-stamp.png' | asset_url }}" alt="{{ shop.name }}" width="94" height="102" loading="lazy">
    {%- endif -%}

    <div class="f-footer-col f-footer-address">{{ section.settings.address }}</div>

    <span class="f-footer-div" aria-hidden="true"></span>

    <div class="f-footer-col">
      <p class="f-footer-h">{{ section.settings.hours_label | escape }}</p>
      <div class="f-footer-body">{{ section.settings.hours }}</div>
    </div>

    <span class="f-footer-div" aria-hidden="true"></span>

    <div class="f-footer-col">
      <p class="f-footer-h">{{ section.settings.social_label | escape }}</p>
      <div class="f-footer-social">
        {%- if section.settings.instagram != blank -%}
          <a href="{{ section.settings.instagram }}" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="4" y="4" width="16" height="16" rx="4.5"/><circle cx="12" cy="12" r="3.6"/><circle cx="16.8" cy="7.2" r="0.9" fill="currentColor" stroke="none"/></svg>
          </a>
        {%- endif -%}
        {%- if section.settings.facebook != blank -%}
          <a href="{{ section.settings.facebook }}" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M13.4 20.5v-6.8h2.3l0.4-2.7h-2.7V9.3c0-0.8 0.4-1.5 1.6-1.5h1.2V5.4s-1.1-0.2-2.1-0.2c-2.2 0-3.6 1.3-3.6 3.7v2.1H8.2v2.7h2.3v6.8"/></svg>
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
  {%- if section.settings.show_copyright -%}
    <p class="f-footer-copy">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. Всички права запазени.</p>
  {%- endif -%}
</footer>

{% style %}
  .f-footer {
    background: var(--f-black);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }
  .f-footer-inner {
    display: flex;
    align-items: center;
    gap: clamp(24px, 4.5vw, 64px);
    max-width: 1170px;
    margin: 0 auto;
    padding: 30px 4.7% 26px;
  }
  .f-footer-stamp { width: 94px; height: auto; flex: 0 0 auto; }
  .f-footer-col { min-width: 0; }
  .f-footer-address { font-size: 12px; line-height: 1.95; color: #b9b3a6; }
  .f-footer-address p { margin: 0; }
  .f-footer-h {
    font-family: var(--f-serif);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--f-cream);
    margin: 0 0 10px;
  }
  .f-footer-body { font-size: 12px; line-height: 1.85; color: #b9b3a6; }
  .f-footer-body p { margin: 0; }
  .f-footer-div { align-self: stretch; width: 1px; background: rgba(255, 255, 255, 0.12); }
  .f-footer-social { display: flex; gap: 12px; }
  .f-footer-social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 50%;
    color: #cfc9bd;
    transition: border-color 0.25s ease, color 0.25s ease;
  }
  .f-footer-social a:hover { border-color: var(--f-gold); color: var(--f-gold); }
  .f-footer-social svg { width: 15px; height: 15px; }
  .f-footer-copy {
    margin: 0;
    padding: 0 4.7% 22px;
    max-width: 1170px;
    margin: 0 auto;
    font-size: 10.5px;
    letter-spacing: 0.06em;
    color: #6d685e;
  }

  @media (max-width: 849px) {
    .f-footer-inner { flex-direction: column; text-align: center; gap: 22px; padding-top: 38px; }
    .f-footer-div { display: none; }
    .f-footer-copy { text-align: center; }
  }
{% endstyle %}

{% schema %}
{
  "name": "Fujiyama футър",
  "enabled_on": { "groups": ["footer"] },
  "presets": [{ "name": "Fujiyama футър" }],
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Печат (кръгло лого)" },
    { "type": "richtext", "id": "address", "label": "Адрес", "default": "<p>Пазарджик, България<br>ул. Цар Иван Шишман 15<br>+359 88 123 4567<br>info@sushichef.bg</p>" },
    { "type": "text", "id": "hours_label", "label": "Етикет работно време", "default": "Работно време" },
    { "type": "richtext", "id": "hours", "label": "Работно време", "default": "<p>Понеделник – Неделя<br>12:00 – 23:00</p>" },
    { "type": "text", "id": "social_label", "label": "Етикет социални мрежи", "default": "Последвай ни" },
    { "type": "url", "id": "instagram", "label": "Instagram" },
    { "type": "url", "id": "facebook", "label": "Facebook" },
    { "type": "checkbox", "id": "show_copyright", "label": "Показвай копирайт ред", "default": true }
  ]
}
{% endschema %}
