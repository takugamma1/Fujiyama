{%- comment -%}
  FUJIYAMA collection page — group-aware.
  Collections are flat in Shopify, so groups are defined in the editable config
  block below (group key | title | icon | space-separated sub-collection handles).
  The page shows: a round-image carousel of the MAIN groups (name inside, over a
  gradient), the current group title, the group's sub-collections as bubbles, and
  the active sub-collection's product grid with the gold "+" add-to-cart.

  TO EDIT GROUPS: change the g_titles / g_icons / g_subs lists (keep them aligned).
{%- endcomment -%}

{%- liquid
  assign g_titles = 'Суши,Азиатска,Бургери,Паста,Салати,Основни,Десерти,Напитки,Вино & бар' | split: ','
  assign g_icons  = 'fish,asian,burger,pasta,salad,meat,cake,cup,wine' | split: ','
  assign g_subs_joined = 'урамаки хосомаки футомаки нигири сашими сетове суши-бургер суши-хотдог поке-суши||азиатски-предложения||бургери||паста ризото||салати обедни-салати||основни риба||десерти||напитки||алкохолни-напитки'
  assign g_subs = g_subs_joined | split: '||'

  assign cur = collection.handle
  assign gidx = -1
  for s in g_subs
    assign padded = ' ' | append: s | append: ' '
    assign needle = ' ' | append: cur | append: ' '
    if padded contains needle
      assign gidx = forloop.index0
      break
    endif
  endfor

  if gidx == -1
    assign group_title = collection.title
    assign group_subs_list = cur | split: ' '
  else
    assign group_title = g_titles[gidx]
    assign group_subs_list = g_subs[gidx] | split: ' '
  endif
-%}

<section class="f-section f-cg">
  <a class="f-cg-back" href="{{ section.settings.back_url | default: '/pages/menu' }}">
    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" width="14" height="14" aria-hidden="true"><path d="M14 8H3M7 3.5 2.5 8 7 12.5"/></svg>
    {{ section.settings.back_label | default: 'Назад към менюто' }}
  </a>

  {%- comment -%} ===== round carousel of main groups ===== {%- endcomment -%}
  <nav class="f-cg-groups" aria-label="Категории">
    <div class="f-cg-groups-track">
      {%- for title in g_titles -%}
        {%- assign gi = forloop.index0 -%}
        {%- assign first_sub = g_subs[gi] | split: ' ' | first -%}
        {%- assign gc = collections[first_sub] -%}
        {%- assign gimg = gc.image -%}
        {%- if gimg == blank -%}
          {%- for p in gc.products limit: 5 -%}{%- if p.featured_image -%}{%- assign gimg = p.featured_image -%}{%- break -%}{%- endif -%}{%- endfor -%}
        {%- endif -%}
        <a class="f-cg-group{% if gi == gidx %} is-active{% endif %}" href="{{ gc.url | default: '#' }}"{% if gi == gidx %} aria-current="page"{% endif %}>
          <span class="f-cg-circle">
            {%- if gimg != blank -%}
              {{ gimg | image_url: width: 240 | image_tag: loading: 'lazy', widths: '120,200,240', alt: title | escape }}
            {%- else -%}
              <span class="f-cg-circle-ph">{% render 'fujiyama-icon', name: g_icons[gi] %}</span>
            {%- endif -%}
            <span class="f-cg-circle-name">{{ title }}</span>
          </span>
        </a>
      {%- endfor -%}
    </div>
  </nav>

  {%- comment -%} ===== group title + wavy underline ===== {%- endcomment -%}
  <header class="f-cg-head">
    <h1 class="f-display f-cg-title">{{ group_title }}</h1>
    <svg class="f-cg-wave" viewBox="0 0 120 6" preserveAspectRatio="none" aria-hidden="true"><path d="M0 3 Q5 0 10 3 T20 3 T30 3 T40 3 T50 3 T60 3 T70 3 T80 3 T90 3 T100 3 T110 3 T120 3" fill="none" stroke="currentColor" stroke-width="1.2"/></svg>
    {%- if collection.description != blank -%}<div class="f-cg-desc">{{ collection.description }}</div>{%- endif -%}
  </header>

  {%- comment -%} ===== sub-collection bubbles (this group only) ===== {%- endcomment -%}
  {%- if group_subs_list.size > 1 -%}
    <nav class="f-cg-subs" aria-label="Подкатегории">
      <div class="f-cg-subs-track">
        {%- for h in group_subs_list -%}
          {%- assign sc = collections[h] -%}
          {%- if sc == blank or sc.products_count == 0 -%}{%- continue -%}{%- endif -%}
          <a class="f-cg-sub{% if h == cur %} is-active{% endif %}" href="{{ sc.url }}"{% if h == cur %} aria-current="page"{% endif %}>{{ sc.title }}</a>
        {%- endfor -%}
      </div>
    </nav>
  {%- endif -%}

  {%- comment -%} ===== products of the active sub-collection ===== {%- endcomment -%}
  {%- paginate collection.products by 24 -%}
    <ul class="f-col-grid" role="list">
      {%- for product in collection.products -%}
        <li class="f-pc">
          <button type="button" class="f-pc-media" data-quick tabindex="-1" aria-hidden="true">
            {%- if product.featured_image -%}
              {{ product.featured_image | image_url: width: 600 | image_tag: class: 'f-pc-img', loading: 'lazy', widths: '260,400,600', sizes: '(max-width:749px) 44vw, 240px', alt: product.title | escape }}
            {%- else -%}
              <span class="f-pc-ph" aria-hidden="true">膳</span>
            {%- endif -%}
          </button>
          <div class="f-pc-body">
            <button type="button" class="f-pc-title" data-quick>{{ product.title | escape }}</button>
            {%- if product.description != blank -%}<p class="f-pc-desc">{{ product.description | strip_html | truncate: 72 }}</p>{%- endif -%}
            <div class="f-pc-foot">
              <span class="f-pc-price">{%- if product.price_varies -%}от {% endif -%}{{ product.price | money }}</span>
              <button type="button" class="f-pc-add" data-quick data-title="{{ product.title | escape }}" aria-label="Добави {{ product.title | escape }} в количката"{% unless product.available %} disabled aria-disabled="true"{% endunless %}>
                <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M8 2.5v11M2.5 8h11"/></svg>
              </button>
            </div>
          </div>
          <script type="application/json" class="f-pc-json">
            {
              "id": {{ product.id }},
              "title": {{ product.title | json }},
              "description": {{ product.description | json }},
              "available": {{ product.available }},
              "price_varies": {{ product.price_varies }},
              "price_formatted": {{ product.price | money | json }},
              "featured_image": {% if product.featured_image %}{{ product.featured_image | image_url: width: 720 | json }}{% else %}null{% endif %},
              "options": [
                {%- for opt in product.options_with_values -%}
                { "name": {{ opt.name | json }}, "values": {{ opt.values | json }} }{%- unless forloop.last -%},{%- endunless -%}
                {%- endfor -%}
              ],
              "variants": [
                {%- for v in product.variants -%}
                { "id": {{ v.id }}, "title": {{ v.title | json }}, "options": {{ v.options | json }}, "available": {{ v.available }}, "price_formatted": {{ v.price | money | json }}, "image": {% if v.image %}{{ v.image | image_url: width: 720 | json }}{% else %}null{% endif %} }{%- unless forloop.last -%},{%- endunless -%}
                {%- endfor -%}
              ]
            }
          </script>
        </li>
      {%- else -%}
        <li class="f-col-empty">В тази колекция още няма продукти.</li>
      {%- endfor -%}
    </ul>

    {%- if paginate.pages > 1 -%}
      <nav class="f-col-pager" aria-label="Страници">
        {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}" class="f-col-pager-link">←</a>{%- endif -%}
        {%- for part in paginate.parts -%}
          {%- if part.is_link -%}<a href="{{ part.url }}" class="f-col-pager-link">{{ part.title }}</a>
          {%- else -%}<span class="f-col-pager-link is-active">{{ part.title }}</span>{%- endif -%}
        {%- endfor -%}
        {%- if paginate.next -%}<a href="{{ paginate.next.url }}" class="f-col-pager-link">→</a>{%- endif -%}
      </nav>
    {%- endif -%}
  {%- endpaginate -%}
</section>

{% render 'fujiyama-quick-add' %}

{% style %}
  .f-cg { padding: clamp(18px,2.6vw,36px) 4.7% clamp(48px,6vw,84px); }
  .f-cg-back {
    display: inline-flex; align-items: center; gap: 9px;
    font-size: 11px; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--f-cream-dim); margin-bottom: clamp(20px,2.4vw,30px); transition: color .25s, gap .25s;
  }
  .f-cg-back:hover { color: var(--f-gold); gap: 13px; }

  /* round group carousel */
  .f-cg-groups { margin-bottom: clamp(26px,3vw,42px); }
  .f-cg-groups-track {
    display: flex; gap: clamp(14px,1.8vw,26px); overflow-x: auto; padding: 4px 2px 14px;
    scrollbar-width: thin; scrollbar-color: rgba(199,161,113,.5) transparent; -webkit-overflow-scrolling: touch;
  }
  .f-cg-groups-track::-webkit-scrollbar { height: 4px; }
  .f-cg-groups-track::-webkit-scrollbar-thumb { background: rgba(199,161,113,.5); border-radius: 4px; }
  .f-cg-group { flex: 0 0 auto; }
  .f-cg-circle {
    position: relative; display: block; width: clamp(78px,9vw,108px); aspect-ratio: 1;
    border-radius: 50%; overflow: hidden; border: 1px solid rgba(232,225,210,.16);
    transition: border-color .25s ease, transform .25s ease;
  }
  .f-cg-group:hover .f-cg-circle { transform: translateY(-3px); border-color: rgba(199,161,113,.6); }
  .f-cg-circle img { width: 100%; height: 100%; object-fit: cover; }
  .f-cg-circle-ph { display: flex; align-items: center; justify-content: center; width: 100%; height: 100%; background: #14130f; color: rgba(199,161,113,.5); }
  .f-cg-circle-ph svg { width: 38%; height: 38%; }
  .f-cg-circle::after { content: ''; position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,.82) 0%, rgba(0,0,0,.25) 48%, transparent 72%); }
  .f-cg-circle-name {
    position: absolute; left: 4px; right: 4px; bottom: clamp(8px,1vw,12px); z-index: 2;
    text-align: center; font-size: clamp(9px,1vw,12px); font-weight: 600; letter-spacing: 0.04em;
    color: var(--f-cream); line-height: 1.1;
  }
  .f-cg-group.is-active .f-cg-circle { border-color: var(--f-gold); box-shadow: inset 0 0 0 2px var(--f-gold); }
  .f-cg-group.is-active .f-cg-circle-name { color: var(--f-gold); }

  /* group title + wavy underline */
  .f-cg-head { margin-bottom: clamp(18px,2vw,28px); }
  .f-cg-title { margin: 0; font-size: clamp(30px,4vw,52px); letter-spacing: 0.04em; text-transform: uppercase; }
  .f-cg-wave { display: block; width: clamp(120px,16vw,200px); height: 7px; color: var(--f-gold); margin-top: 10px; }
  .f-cg-desc { margin: 16px 0 0; max-width: 62ch; font-size: 14px; line-height: 1.7; color: var(--f-body); }
  .f-cg-desc p { margin: 0 0 .5em; }

  /* sub-collection bubbles */
  .f-cg-subs { margin-bottom: clamp(22px,2.6vw,34px); }
  .f-cg-subs-track {
    display: flex; flex-wrap: wrap; gap: 10px;
  }
  .f-cg-sub {
    padding: 9px 18px; border-radius: 999px; border: 1px solid rgba(232,225,210,.16);
    font-size: 11px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--f-cream-dim); white-space: nowrap; transition: color .2s, border-color .2s, background .2s;
  }
  .f-cg-sub:hover { color: var(--f-cream); border-color: rgba(199,161,113,.55); }
  .f-cg-sub.is-active { background: var(--f-gold); border-color: var(--f-gold); color: var(--f-ink); }

  /* product grid (shared card styling) */
  .f-col-grid { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(214px, 1fr)); gap: clamp(12px,1.2vw,18px); }
  .f-pc { display: flex; flex-direction: column; border: 1px solid rgba(232,225,210,.1); border-radius: 12px; overflow: hidden; background: rgba(255,255,255,.022); transition: border-color .3s, transform .3s; }
  .f-pc:hover { border-color: rgba(199,161,113,.4); transform: translateY(-3px); }
  .f-pc-media { display: block; width: 100%; aspect-ratio: 1; overflow: hidden; background: #14130f; border: 0; padding: 0; cursor: pointer; }
  .f-pc-img { width: 100%; height: 100%; object-fit: cover; transition: transform .5s ease; }
  .f-pc:hover .f-pc-img { transform: scale(1.05); }
  .f-pc-ph { display: flex; align-items: center; justify-content: center; width: 100%; height: 100%; font-family: 'Noto Serif JP', var(--f-serif); font-size: 2.2rem; color: rgba(199,161,113,.45); }
  .f-pc-body { display: flex; flex-direction: column; gap: 8px; padding: 16px 16px 18px; flex: 1 1 auto; }
  .f-pc-title { display: block; width: 100%; text-align: left; background: none; border: 0; padding: 0; cursor: pointer; font-family: var(--f-sans); font-size: 13px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--f-cream); line-height: 1.3; transition: color .2s; }
  .f-pc-title:hover { color: var(--f-gold); }
  .f-pc-desc { margin: 0; font-size: 12px; line-height: 1.5; color: rgba(232,225,210,.62); }
  .f-pc-foot { margin-top: auto; padding-top: 6px; display: flex; align-items: center; justify-content: space-between; gap: 10px; }
  .f-pc-price { font-family: var(--f-serif); font-size: 17px; color: var(--f-cream); white-space: nowrap; }
  .f-pc-add { flex: 0 0 auto; width: 38px; height: 38px; border-radius: 50%; border: 1px solid rgba(199,161,113,.6); background: transparent; color: var(--f-gold); cursor: pointer; display: inline-flex; align-items: center; justify-content: center; transition: background .25s, color .25s, transform .2s; }
  .f-pc-add svg { width: 15px; height: 15px; }
  .f-pc-add:hover { background: var(--f-gold); color: var(--f-ink); }
  .f-pc-add:active { transform: scale(.92); }
  .f-pc-add[disabled] { opacity: .35; cursor: not-allowed; }
  .f-pc-add.is-added { background: var(--f-gold); color: var(--f-ink); }
  .f-col-empty { grid-column: 1 / -1; color: var(--f-body); padding: 40px 0; text-align: center; }
  .f-col-pager { display: flex; gap: 8px; justify-content: center; margin-top: 36px; }
  .f-col-pager-link { min-width: 38px; height: 38px; padding: 0 10px; display: inline-flex; align-items: center; justify-content: center; border: 1px solid rgba(232,225,210,.16); border-radius: 8px; font-size: 13px; color: var(--f-cream-dim); transition: border-color .2s, color .2s; }
  .f-col-pager-link:hover { border-color: rgba(199,161,113,.5); color: var(--f-cream); }
  .f-col-pager-link.is-active { background: var(--f-gold); border-color: var(--f-gold); color: var(--f-ink); }

  @media (max-width: 749px) {
    .f-col-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    .f-pc-title { font-size: 12px; }
  }
{% endstyle %}

{% schema %}
{
  "name": "Fujiyama колекция",
  "settings": [
    { "type": "text", "id": "back_label", "label": "Текст за връщане", "default": "Назад към менюто" },
    { "type": "text", "id": "back_url", "label": "Линк за връщане", "default": "/pages/menu" },
    { "type": "paragraph", "content": "Групите се редактират в кода на секцията (g_titles / g_icons / g_subs)." }
  ],
  "presets": [{ "name": "Fujiyama колекция" }]
}
{% endschema %}
