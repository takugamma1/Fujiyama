{%- comment -%}
  FUJIYAMA hero — giant serif wordmark over Mt. Fuji artwork with sushi platter.
  The artwork is a feathered crop of the original mockup; the wordmark is live
  text scaled in container-query units (design width 1170px → 1cqw = 11.7px).
{%- endcomment -%}

<section class="f-section f-hero" id="nachalo">
  <div class="f-board f-hero-board">

    <h1 class="f-abs f-hero-title"><span class="f-hero-word">{{ section.settings.title | escape }}</span></h1>

    {%- if section.settings.art != blank -%}
      {{ section.settings.art | image_url: width: 2340 | image_tag:
        alt: section.settings.art_alt,
        class: 'f-abs f-hero-art',
        loading: 'eager',
        fetchpriority: 'high'
      }}
    {%- else -%}
      <img class="f-abs f-hero-art" src="{{ 'fujiyama-hero-art.webp' | asset_url }}"
        alt="{{ section.settings.art_alt | escape }}" width="1170" height="542"
        loading="eager" fetchpriority="high">
    {%- endif -%}
  </div>
</section>

{% style %}
  .f-hero { overflow: hidden; }
  .f-hero-board { position: relative; }

  /* the image flows naturally (it defines the section height and sits at the
     top — no fixed empty box) and its top+bottom feather into the section bg so
     the picture's own background merges seamlessly with the theme + next section */
  .f-hero-art {
    position: relative;
    display: block;
    width: 100%;
    height: auto;
    z-index: 2;
    -webkit-mask-image: linear-gradient(to bottom, transparent 0, #000 4.5%, #000 82%, transparent 100%);
            mask-image: linear-gradient(to bottom, transparent 0, #000 4.5%, #000 82%, transparent 100%);
  }
  .f-hero-title {
    position: absolute;
    top: 1cqw;
    left: 0;
    width: 100%;
    display: flex;
    justify-content: center;   /* true centering, immune to the letter-spacing quirk */
    white-space: nowrap;
    z-index: 3;
  }
  .f-hero-word {
    display: inline-block;
    font-family: 'Italiana', var(--f-serif);
    font-weight: 400;
    font-size: 22cqw;
    line-height: 1.05;
    letter-spacing: 0.1em;
    margin-right: -0.1em;      /* cancel the trailing letter-spacing so it sits dead-centre */
    transform: scaleX(0.88);   /* mockup wordmark is ultra-condensed */
    transform-origin: center;
    color: #ddd5c3;
  }
{% endstyle %}

{% schema %}
{
  "name": "Fujiyama хедър арт",
  "settings": [
    { "type": "text", "id": "title", "label": "Заглавие", "default": "FUJIYAMA" },
    { "type": "image_picker", "id": "art", "label": "Арт изображение (планина + плато)" },
    { "type": "text", "id": "art_alt", "label": "Alt текст на изображението", "default": "Плато с нигири и маки суши пред планината Фуджи" }
  ],
  "presets": [{ "name": "Fujiyama хедър арт" }]
}
{% endschema %}
