{%- comment -%}
  FUJIYAMA header — split navigation with centered round emblem.
  Matches the "Group 6" design: left links / emblem / right links on the
  shared chalkboard texture, so it melts into the hero with no visible edge.
{%- endcomment -%}

<header class="f-section f-header{% if template contains 'menu' or template contains 'reservation' or template contains 'faq' or template contains 'about' %} f-header--inverse{% endif %}" id="f-header">
  <div class="f-header-inner">
    <button class="f-burger" aria-label="Меню" aria-expanded="false" aria-controls="f-mobile-nav">
      <span></span><span></span><span></span>
    </button>

    <nav class="f-nav f-nav-left" aria-label="Основна навигация">
      <a href="{{ section.settings.link_1_url }}">{{ section.settings.link_1_label }}</a>
      <a href="{{ section.settings.link_2_url }}">{{ section.settings.link_2_label }}</a>
      <a href="{{ section.settings.link_3_url }}">{{ section.settings.link_3_label }}</a>
    </nav>

    <a href="{{ routes.root_url }}" class="f-emblem" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        {{ section.settings.logo | image_url: width: 120 | image_tag: alt: shop.name, class: 'f-emblem-img' }}
      {%- else -%}
        <img src="{{ 'fujiyama-badge.png' | asset_url }}" alt="{{ shop.name }}" class="f-emblem-img" width="60" height="60">
      {%- endif -%}
    </a>

    <nav class="f-nav f-nav-right" aria-label="Допълнителна навигация">
      <a href="{{ section.settings.link_4_url }}">{{ section.settings.link_4_label }}</a>
      <a href="{{ section.settings.link_5_url }}">{{ section.settings.link_5_label }}</a>
      <a href="{{ section.settings.link_6_url }}">{{ section.settings.link_6_label }}</a>
      {%- if section.settings.show_cart -%}
        <a href="{{ routes.cart_url }}" class="f-cart" aria-label="Количка">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18" aria-hidden="true">
            <path d="M6 7h12l-1.2 11.2a1.5 1.5 0 0 1-1.5 1.3H8.7a1.5 1.5 0 0 1-1.5-1.3L6 7z"/>
            <path d="M9 9V6a3 3 0 0 1 6 0v3"/>
          </svg>
          {%- if cart.item_count > 0 -%}<span class="f-cart-count">{{ cart.item_count }}</span>{%- endif -%}
        </a>
      {%- endif -%}
    </nav>
  </div>

  <nav class="f-mobile-nav" id="f-mobile-nav" aria-label="Мобилна навигация" hidden>
    <a href="{{ section.settings.link_1_url }}">{{ section.settings.link_1_label }}</a>
    <a href="{{ section.settings.link_2_url }}">{{ section.settings.link_2_label }}</a>
    <a href="{{ section.settings.link_3_url }}">{{ section.settings.link_3_label }}</a>
    <a href="{{ section.settings.link_4_url }}">{{ section.settings.link_4_label }}</a>
    <a href="{{ section.settings.link_5_url }}">{{ section.settings.link_5_label }}</a>
    <a href="{{ section.settings.link_6_url }}">{{ section.settings.link_6_label }}</a>
  </nav>
</header>

<script>
  (function () {
    var header = document.getElementById('f-header');
    var burger = header.querySelector('.f-burger');
    var nav = header.querySelector('.f-mobile-nav');
    burger.addEventListener('click', function () {
      var open = nav.hasAttribute('hidden');
      if (open) { nav.removeAttribute('hidden'); } else { nav.setAttribute('hidden', ''); }
      burger.setAttribute('aria-expanded', open ? 'true' : 'false');
      burger.classList.toggle('is-open', open);
    });
    nav.addEventListener('click', function (e) {
      if (e.target.tagName === 'A') {
        nav.setAttribute('hidden', '');
        burger.setAttribute('aria-expanded', 'false');
        burger.classList.remove('is-open');
      }
    });

    // Inverse pages (cream hero on top): header is a cream bar over the hero,
    // then swaps to the dark texture once scrolled into the dark sections.
    if (header.classList.contains('f-header--inverse')) {
      var onScroll = function () { header.classList.toggle('is-stuck', window.scrollY > 90); };
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });
    }
  })();
</script>

{% style %}
  .f-header {
    position: sticky;
    top: 0;
    z-index: 60;
    transition: background 0.3s ease, box-shadow 0.3s ease;
  }

  /* Inverse mode: dark text on cream, blending into the menu hero's cream top */
  .f-header--inverse.f-section { background: #f6f2ec; }
  .f-header--inverse .f-nav a { color: #4a4336; }
  .f-header--inverse .f-nav a:hover { color: #1f1c16; }
  .f-header--inverse .f-cart { color: #4a4336; }
  .f-header--inverse .f-cart:hover { color: #1f1c16; }
  /* the logo is a faithful cream seal; it blends on the cream bar (black art shows) and reads on dark */
  .f-header--inverse .f-burger span { background: #3a352c; }
  /* Once scrolled past the hero, revert to the dark charcoal bar */
  .f-header--inverse.is-stuck.f-section {
    background: #1f1e1c url('fujiyama-texture.jpg') repeat;
    background-size: 400px 400px;
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.05);
  }
  .f-header--inverse.is-stuck .f-nav a,
  .f-header--inverse.is-stuck .f-cart { color: var(--f-cream-dim); }
  .f-header--inverse.is-stuck .f-nav a:hover,
  .f-header--inverse.is-stuck .f-cart:hover { color: var(--f-cream); }
  .f-header--inverse.is-stuck .f-emblem-img { filter: none; }
  .f-header--inverse.is-stuck .f-burger span { background: var(--f-cream); }
  .f-header-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    height: 56px;
    padding: 0 4.7%;
  }
  .f-nav {
    display: flex;
    align-items: center;
    gap: clamp(18px, 3.4vw, 46px);
  }
  .f-nav-left { justify-content: flex-start; }
  .f-nav-right { justify-content: flex-end; }
  .f-nav a {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--f-cream-dim);
    transition: color 0.25s ease;
    white-space: nowrap;
  }
  .f-nav a:hover { color: var(--f-cream); }
  .f-emblem {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4px 26px 0;
  }
  .f-emblem-img { width: auto; height: 46px; }
  .f-cart { position: relative; display: inline-flex; color: var(--f-cream-dim); }
  .f-cart:hover { color: var(--f-cream); }
  .f-cart-count {
    position: absolute;
    top: -7px;
    right: -9px;
    background: var(--f-gold);
    color: var(--f-ink);
    font-size: 9px;
    font-weight: 700;
    line-height: 1;
    padding: 3px 5px;
    border-radius: 99px;
  }
  .f-burger { display: none; }
  .f-mobile-nav { display: none; }

  @media (max-width: 849px) {
    .f-nav { display: none; }
    .f-header-inner { grid-template-columns: 48px 1fr 48px; }
    .f-emblem { padding: 4px 0 0; }
    .f-burger {
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 5px;
      width: 40px;
      height: 40px;
      background: none;
      border: 0;
      cursor: pointer;
      padding: 8px;
    }
    .f-burger span {
      display: block;
      height: 1.5px;
      width: 100%;
      background: var(--f-cream);
      transition: transform 0.25s ease, opacity 0.25s ease;
    }
    .f-burger.is-open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
    .f-burger.is-open span:nth-child(2) { opacity: 0; }
    .f-burger.is-open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }
    .f-mobile-nav {
      display: flex;
      flex-direction: column;
      padding: 6px 24px 18px;
    }
    .f-mobile-nav[hidden] { display: none; }
    .f-mobile-nav a {
      padding: 13px 0;
      font-size: 12px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--f-cream-dim);
      border-bottom: 1px solid rgba(232, 225, 210, 0.08);
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Fujiyama header",
  "enabled_on": { "groups": ["header"] },
  "presets": [{ "name": "Fujiyama header" }],
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Лого (кръгъл печат)" },
    { "type": "checkbox", "id": "show_cart", "label": "Показвай количка", "default": true },
    { "type": "header", "content": "Линкове вляво" },
    { "type": "text", "id": "link_1_label", "label": "Линк 1 — текст", "default": "Начало" },
    { "type": "text", "id": "link_1_url", "label": "Линк 1 — адрес", "default": "/" },
    { "type": "text", "id": "link_2_label", "label": "Линк 2 — текст", "default": "Меню" },
    { "type": "text", "id": "link_2_url", "label": "Линк 2 — адрес", "default": "/pages/menu" },
    { "type": "text", "id": "link_3_label", "label": "Линк 3 — текст", "default": "Резервации" },
    { "type": "text", "id": "link_3_url", "label": "Линк 3 — адрес", "default": "/pages/reservation" },
    { "type": "header", "content": "Линкове вдясно" },
    { "type": "text", "id": "link_4_label", "label": "Линк 4 — текст", "default": "За нас" },
    { "type": "text", "id": "link_4_url", "label": "Линк 4 — адрес", "default": "/pages/about" },
    { "type": "text", "id": "link_5_label", "label": "Линк 5 — текст", "default": "Галерия" },
    { "type": "text", "id": "link_5_url", "label": "Линк 5 — адрес", "default": "/collections/all" },
    { "type": "text", "id": "link_6_label", "label": "Линк 6 — текст", "default": "Контакти" },
    { "type": "text", "id": "link_6_url", "label": "Линк 6 — адрес", "default": "/#kontakti" }
  ]
}
{% endschema %}
