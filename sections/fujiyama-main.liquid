{%- comment -%}
  FUJIYAMA "discover your taste" card row.
  Desktop: inpainted artboard crop (design y1532-2083, 1170x551)
  with live text/links positioned in container-query units (1cqw = 11.7px).
  The chef story that used to sit above now lives in fujiyama-chef.liquid.
  Mobile: restacked flow using individual asset crops.
{%- endcomment -%}

{%- assign card_geo = '3.418,17.009|22.137,16.838|40.684,17.265|59.744,17.094|78.462,17.436' | split: '|' -%}

<section class="f-section f-main">
  <span class="f-anchor" id="kolekcii"></span>

  {%- comment -%} ============ DESKTOP ARTBOARD ============ {%- endcomment -%}
  <div class="f-board f-main-board">
    {%- if section.settings.art != blank -%}
      {{ section.settings.art | image_url: width: 2340 | image_tag: alt: '', class: 'f-main-art', loading: 'lazy' }}
    {%- else -%}
      <img class="f-main-art" src="{{ 'fujiyama-cards-art.webp' | asset_url }}" alt="" width="1170" height="551" loading="lazy">
    {%- endif -%}

    <h2 class="f-abs f-display f-coll-title">{{ section.settings.coll_title | escape }}</h2>
    <p class="f-abs f-coll-sub">{{ section.settings.coll_sub | escape }}</p>

    {%- for block in section.blocks limit: 5 -%}
      {%- assign geo = card_geo[forloop.index0] | split: ',' -%}
      <a class="f-abs f-card" href="{{ block.settings.url | default: '/collections/all' }}"
         style="left: {{ geo[0] }}cqw; width: {{ geo[1] }}cqw;" {{ block.shopify_attributes }}>
        <span class="f-card-bubble">
            <span class="f-card-title">{{ block.settings.title | escape }}</span>
            <span class="f-card-foot">
              <span class="f-card-desc">{{ block.settings.desc | escape }}</span>
              <span class="f-arrow f-card-arrow" aria-hidden="true"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M2 8h11M9 3.5 13.5 8 9 12.5"/></svg></span>
            </span>
          </span>
      </a>
    {%- endfor -%}
  </div>

  {%- comment -%} ============ MOBILE FLOW ============ {%- endcomment -%}
  <div class="f-main-mobile">
    <div class="f-mob-coll">
      <h2 class="f-display f-mob-coll-title">{{ section.settings.coll_title | escape }}</h2>
      <p class="f-mob-coll-sub">{{ section.settings.coll_sub | escape }}</p>
      <div class="f-mob-cards">
        {%- for block in section.blocks limit: 5 -%}
          <a class="f-mob-card" href="{{ block.settings.url | default: '/collections/all' }}"
             style="background-image: url('{{ 'fujiyama-card-' | append: forloop.index | asset_url }}');">
            <span class="f-card-bubble">
            <span class="f-card-title">{{ block.settings.title | escape }}</span>
            <span class="f-card-foot">
              <span class="f-card-desc">{{ block.settings.desc | escape }}</span>
              <span class="f-arrow f-card-arrow" aria-hidden="true"><svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M2 8h11M9 3.5 13.5 8 9 12.5"/></svg></span>
            </span>
          </span>
          </a>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% style %}
  .f-main .f-anchor { display: block; scroll-margin-top: 70px; }
  .f-main-board { aspect-ratio: 1170 / 551; }
  .f-main-art {
    position: absolute; inset: 0; width: 100%; height: 100%;
    /* feather the crop's top edge into the section bg so it meets whatever
       sits above at the same colour — seamless merge */
    -webkit-mask-image: linear-gradient(to bottom, transparent 0, #000 8%);
            mask-image: linear-gradient(to bottom, transparent 0, #000 8%);
  }

  /* collections heading — design abs y → rel cqw ((y-1532)/11.7) */
  .f-coll-title {
    top: 1.2cqw;
    left: 0;
    width: 100%;
    text-align: center;
    font-size: 5.0cqw;
    letter-spacing: 0.09em;
    text-indent: 0.09em;
    text-transform: uppercase;
  }
  .f-coll-sub {
    top: 9.0cqw;
    left: 0;
    width: 100%;
    text-align: center;
    font-size: 1.11cqw;
    letter-spacing: 0.3em;
    text-indent: 0.3em;
    text-transform: uppercase;
    color: #a8a08c;
  }

  /* card hot-zones over the baked card art */
  .f-card {
    top: 15.21cqw;
    height: 31.8cqw;
    border-radius: 0.7cqw;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }
  .f-card:hover {
    transform: translateY(-0.34cqw);
    box-shadow: 0 1.2cqw 2.6cqw rgba(0, 0, 0, 0.45);
  }
  /* content sits in a dark glass "bubble" pinned to the card bottom */
  .f-card-bubble {
    position: absolute;
    left: 0.6cqw;
    right: 0.6cqw;
    bottom: 0.6cqw;
    padding: 1.5cqw 1.5cqw;
    display: flex;
    flex-direction: column;
    gap: 0.7cqw;
    background: rgba(15, 12, 9, 0.82);
    -webkit-backdrop-filter: blur(5px);
    backdrop-filter: blur(5px);
    border: 1px solid rgba(232, 225, 210, 0.14);
    border-radius: 0.65cqw;
  }
  .f-card-title {
    font-size: 1.22cqw;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--f-cream);
    line-height: 1.2;
  }
  .f-card-foot { display: flex; align-items: center; justify-content: space-between; gap: 0.9cqw; }
  .f-card-desc { flex: 1 1 auto; font-size: 0.98cqw; line-height: 1.42; color: rgba(232, 225, 210, 0.74); }
  .f-card-arrow { flex: 0 0 auto; width: 3cqw; height: 3cqw; aspect-ratio: 1; }
  .f-card:hover .f-card-arrow { background: var(--f-gold); border-color: var(--f-gold); color: var(--f-ink); }

  .f-main-mobile { display: none; }

  @media (max-width: 849px) {
    .f-main-board { display: none; }
    .f-main-mobile { display: block; padding: 56px 24px 8px; }
    .f-mob-coll { text-align: center; }
    .f-mob-coll-title { font-size: 30px; letter-spacing: 0.08em; text-transform: uppercase; }
    .f-mob-coll-sub {
      font-size: 11px;
      letter-spacing: 0.26em;
      text-transform: uppercase;
      color: #a8a08c;
      margin: 12px 0 26px;
    }
    .f-mob-cards {
      display: flex;
      gap: 14px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      padding: 4px 2px 18px;
      -webkit-overflow-scrolling: touch;
    }
    .f-mob-card {
      position: relative;
      flex: 0 0 62vw;
      max-width: 270px;
      aspect-ratio: 203 / 434;
      background-size: cover;
      background-position: center;
      border-radius: 8px;
      scroll-snap-align: center;
      text-align: left;
    }
    .f-mob-card .f-card-bubble { left: 9px; right: 9px; bottom: 9px; padding: 17px 17px; gap: 9px; border-radius: 14px; }
    .f-mob-card .f-card-title { font-size: 15px; }
    .f-mob-card .f-card-desc { font-size: 12.5px; }
    .f-mob-card .f-card-arrow { width: 42px; height: 42px; }
  }
{% endstyle %}

{% schema %}
{
  "name": "Fujiyama колекции",
  "settings": [
    { "type": "image_picker", "id": "art", "label": "Фоново арт изображение (по подразбиране — вграденото)" },
    { "type": "header", "content": "Колекции" },
    { "type": "text", "id": "coll_label", "label": "Етикет", "default": "Нашите колекции" },
    { "type": "text", "id": "coll_title", "label": "Заглавие", "default": "Открий своя вкус" },
    { "type": "text", "id": "coll_sub", "label": "Подзаглавие", "default": "Свежест, качество и изкуство във всяко ястие" }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Карта",
      "settings": [
        { "type": "text", "id": "title", "label": "Заглавие", "default": "Суши" },
        { "type": "text", "id": "desc", "label": "Описание", "default": "Класика и креативност" },
        { "type": "text", "id": "url", "label": "Линк", "info": "напр. /pages/menu или /collections/урамаки" }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [{ "name": "Fujiyama колекции" }]
}
{% endschema %}
